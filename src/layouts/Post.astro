---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, summary } = post.data;
const { Content } = await post.render();

const formattedDate = date.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
---
<Base title={title} description={summary}>
  <Header />
  <article>
    <header class="mb-10">
      <h1 class="text-3xl font-semibold tracking-tight text-gray-900 mb-2">{title}</h1>
      <p class="text-sm text-gray-400">{formattedDate}</p>
    </header>
    <div class="prose prose-gray max-w-none prose-a:font-normal">
      <Content />
    </div>
  </article>
</Base>
